{
  "expo": {
    "name": "TubeCalc",
    "slug": "TubeCalc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/TubeCalcApp_icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "tubecalc",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "bundleIdentifier": "com.haapasaari.tubecalc",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/TubeCalcApp_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
